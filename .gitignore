# Terraform state files
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform plan files
*.tfplan
*.plan

# Terraform lock file (keep this if you want to pin provider versions)
# .terraform.lock.hcl

# Terraform working directories
**/.terraform/

# Terraform crash logs
crash.log
crash.*.log

# Terraform variable files with sensitive data
!*.tfvars.example
*.tfvars.json
!*.tfvars.json.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# SSH keys
*.pem
*.key
id_rsa
id_rsa.pub

# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Editor directories
.idea/
.vscode/
*.swp
*.swo
